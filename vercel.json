{
  "buildCommand": "cd frontend && npm ci && npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/v1/:path*", "destination": "/api/index" },
    { "source": "/health", "destination": "/api/index" },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ]
}
